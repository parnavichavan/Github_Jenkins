pipeline {
    agent any
    stages {
        stage('Install Dependencies') {
            steps {
                bat 'pip install -r requirements.txt'
            }
        }
        stage('Extract Data') {
            steps {
                bat 'python scripts/extract.py'
            }
        }
        stage('Transform Data') {
            steps {
                bat 'python scripts/transform.py'
            }
        }
        stage('Load Data') {
            steps {
                bat 'python scripts/load.py'
            }
        }
    }
}
